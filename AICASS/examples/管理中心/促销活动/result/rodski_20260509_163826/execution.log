const day=d=>d.getFullYear()+'-'+pad(d.getMonth()+1)+'-'+pad(d.getDate());
async function promoDoc(timeout=30000){
  for(let i=0;i<Math.ceil(timeout/250);i++){
    const f=document.querySelector('#iframeCon,iframe[name="iframeCon"]');
    let doc=null;
    try{doc=f?(f.contentDocument||f.contentWindow.document):document;}catch(e){doc=document;}
    const txt=doc&&doc.body?doc.body.innerText:'';
    if(doc&&doc.body&&(txt.includes('活动时间')||txt.includes('活动名称')))return doc;
    await sleep(250);
  }
  throw new Error('promo doc not loaded');
}
function fiber(el){
  const key=Object.keys(el).find(k=>k.startsWith('__reactInternalInstance')||k.startsWith('__reactFiber'));
  return key?el[key]:null;
}
function findDateFibers(root){
  const out=[];
  let f=fiber(root);
  for(let i=0;i<15&&f;i++,f=f.return){
    const p=f.memoizedProps||{};
    if(typeof p.onChange==='function'&&Array.isArray(p.value)&&p.format==='YYYY-MM-DD HH:mm:ss')out.push({level:i,props:p,type:String((f.type&&f.type.name)||f.type||'')});
    if(typeof p.onChange==='function'&&p.picker==='date'&&p.showTime)out.push({level:i,props:p,type:String((f.type&&f.type.name)||f.type||'')});
  }
  return out;
}
function values(doc){
  const range=doc.querySelector('.br-datepicker-range,.br-rangepicker,.br-datepicker');
  return range?Array.from(range.querySelectorAll('input')).map(el=>({placeholder:el.placeholder,value:el.value,readOnly:el.readOnly})):[];
}
function mk(gen,d){
  let x=gen.getFixedDate(day(d));
  x=gen.setHour(x,d.getHours());
  x=gen.setMinute(x,d.getMinutes());
  x=gen.setSecond(x,d.getSeconds());
  return x;
}
const doc=await promoDoc();
const range=doc.querySelector('.br-datepicker-range,.br-rangepicker,.br-datepicker');
const fibers=findDateFibers(range);
if(!fibers.length)throw new Error('date fibers not found');
const start=new Date(), end=new Date(start.getTime()+10*60*1000);
const startText=fmt(start), endText=fmt(end);
const attempts=[{before:values(doc), fibers:fibers.map(f=>({level:f.level,type:f.type,hasGen:!!f.props.generateConfig}))}];
for(const f of fibers){
  const gen=f.props.generateConfig;
  if(!gen)continue;
  const sv=mk(gen,start), ev=mk(gen,end);
  try{
    f.props.onChange([sv,ev],[startText,endText]);
    await sleep(1000);
    attempts.push({level:f.level,type:f.type,after:values(doc),body:(doc.body&&doc.body.innerText||'').slice(0,500)});
  }catch(e){
    attempts.push({level:f.level,type:f.type,error:String(e).slice(0,500),after:values(doc)});
  }
}
return {startText,endText,attempts};
})()'
