2026-05-09 16:14:24,579 [DEBUG] 数据解析: 'PromoScript.CodexBusinessLineDiagnosis.script' -> '(async()=>{
const sleep=ms=>new Promise(r=>setTimeout(r,ms));
const norm=s=>String(s||'').replace(/\s+/g,'').trim();
const visible=el=>!!el&&el.isConnected&&!!(el.offsetWidth||el.offsetHeight||el.getClientRects().length);
const textOf=el=>norm((el.innerText||el.textContent||el.value||el.getAttribute('title')||el.getAttribute('placeholder')||''));
const brief=el=>{
  if(!el)return null;
  const r=el.getBoundingClientRect();
  return {
    tag:el.tagName,id:el.id||'',cls:String(el.className||'').slice(0,160),
    text:textOf(el).slice(0,160),value:String(el.value||'').slice(0,120),
    placeholder:el.getAttribute('placeholder')||'',role:el.getAttribute('role')||'',
    aria:el.getAttribute('aria-label')||'',html:el.outerHTML.slice(0,700),
    rect:{x:Math.round(r.x),y:Math.round(r.y),w:Math.round(r.width),h:Math.round(r.height)}
  };
};
async function promoDoc(timeout=30000){
  for(let i=0;i<Math.ceil(timeout/250);i++){
    const f=document.querySelector('#iframeCon,iframe[name="iframeCon"]');
    let d=null;
    try{d=f?(f.contentDocument||f.contentWindow.document):document;}catch(e){d=document;}
    const txt=d&&d.body?d.body.innerText:'';
    const url=[location.href,f&&f.getAttribute('src'),d&&d.location&&d.location.href].filter(Boolean).join(' ');
    if(d&&d.body&&(/platform-promotions\/add-edit/.test(url)||txt.includes('业务线')||txt.includes('活动名称')))return d;
    await sleep(250);
  }
  throw new Error('promo doc not loaded');
}
function unique(items){
  const seen=new Set(),out=[];
  for(const x of items){if(x&&!seen.has(x)){seen.add(x);out.push(x);}}
  return out;
}
function anchorsFor(doc,label){
  return Array.from(doc.querySelectorAll('label,span,div,p,td,th')).filter(visible).filter(el=>textOf(el).includes(label));
}
function nearControls(doc,label){
  const anchors=anchorsFor(doc,label);
  const rows=[];
  const controls=[];
  for(const a of anchors){
    let root=a;
    for(let level=0;level<8&&root;level++,root=root.parentElement){
      const found=Array.from(root.querySelectorAll(
        'input:not([type=hidden]),textarea,select,button,[role=combobox],[role=listbox],[class*=select],[class*=Select],[class*=dropdown],[class*=Dropdown],[class*=cascader],[class*=Cascader]'
      )).filter(visible);
      rows.push({level,anchor:brief(a),root:brief(root),found:found.map(brief)});
      controls.push(...found);
    }
  }
  return {anchors:anchors.map(brief),rows,controls:unique(controls)};
}
function visibleTexts(d){
  return Array.from(d.querySelectorAll('li,div,span,a,input,select,option,[role=option]'))
    .filter(visible).map(textOf).filter(t=>t&&t.length<120);
}
function focusedText(d){
  const words=visibleTexts(d);
  return Array.from(new Set(words.filter(t=>/业务线|基础业务|B2B|B2b|b2b|请选择|商城|询价/.test(t)))).slice(0,160);
}
const doc=await promoDoc();
const near=nearControls(doc,'业务线');
const bodyText=(doc.body&&doc.body.innerText||'').slice(0,2500);
const before={top:focusedText(document),frame:focusedText(doc)};
const clicked=[];
for(const ctrl of near.controls.slice(0,20)){
  try{
    ctrl.scrollIntoView({block:'center',inline:'center'});
    await sleep(200);
    ctrl.click();
    await sleep(900);
    clicked.push({ctrl:brief(ctrl),top:focusedText(document),frame:focusedText(doc)});
  }catch(e){
    clicked.push({ctrl:brief(ctrl),error:String(e).slice(0,200)});
  }
}
return {
  url:location.href,
  frameSrc:(document.querySelector('#iframeCon,iframe[name="iframeCon"]')||{}).src||'',
  docUrl:doc.location&&doc.location.href,
  bodyText,
  before,
  anchors:near.anchors,
  rows:near.rows.slice(0,40),
  controls:near.controls.map(brief),
  clicked
};
})()'
