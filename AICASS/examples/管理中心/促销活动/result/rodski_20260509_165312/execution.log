function formatDate(d){const p=n=>String(n).padStart(2,'0');return d.getFullYear()+'-'+p(d.getMonth()+1)+'-'+p(d.getDate())+' '+p(d.getHours())+':'+p(d.getMinutes())+':'+p(d.getSeconds());}
function fillActivityTime(doc){
  const start=new Date(), end=new Date(start.getTime()+10*60*1000);
  const startText=formatDate(start), endText=formatDate(end);
  function day(d){
    const p=n=>String(n).padStart(2,'0');
    return d.getFullYear()+'-'+p(d.getMonth()+1)+'-'+p(d.getDate());
  }
  function fiber(el){
    const key=Object.keys(el).find(k=>k.startsWith('__reactInternalInstance')||k.startsWith('__reactFiber'));
    return key?el[key]:null;
  }
  function mk(gen,d){
    let x=gen.getFixedDate(day(d));
    x=gen.setHour(x,d.getHours());
    x=gen.setMinute(x,d.getMinutes());
    x=gen.setSecond(x,d.getSeconds());
    return x;
  }
  const range=doc.querySelector('.br-datepicker-range,.br-rangepicker,.br-datepicker');
  if(range){
    let f=fiber(range);
    for(let i=0;i<15&&f;i++,f=f.return){
      const p=f.memoizedProps||{};
      if(typeof p.onChange==='function'&&Array.isArray(p.value)&&p.format==='YYYY-MM-DD HH:mm:ss'&&p.generateConfig){
        const value=[mk(p.generateConfig,start),mk(p.generateConfig,end)];
        p.onChange(value,[startText,endText]);
        const inputs=Array.from(range.querySelectorAll('input'));
        if(inputs[0]&&inputs[1]){
          setValue(inputs[0],startText);
          setValue(inputs[1],endText);
        }
        return {start:startText,end:endText};
      }
    }
  }
  let inputs=nearbyInputs(doc,S.activityTime).filter(el=>el.type!=='radio'&&el.type!=='checkbox');
  if(inputs.length<2){
    inputs=q(doc,'input:not([type=hidden]):not([disabled]),input[readonly],textarea:not([disabled])')
      .filter(visible)
      .filter(el=>/(date|time|yyyy|YYYY|\u65e5\u671f)/i.test([el.type,el.placeholder,el.className,el.name].join(' ')));
  }
  if(inputs[0])setValue(inputs[0],startText);
  if(inputs[1])setValue(inputs[1],endText);
  return {start:startText,end:endText};
}
async function chooseBusinessLine(doc,line){
  const target=norm(line||'B2b-\u57fa\u7840\u4e1a\u52a1');
  const loose=s=>norm(s).replace(/[-_\uff0d]/g,'').toLowerCase();
  const targetLoose=loose(target);
  const isTarget=t=>{
    const v=norm(t),l=loose(v);
    return v&&(v===target||v.includes(target)||target.includes(v)||l===targetLoose||l.includes(targetLoose)||targetLoose.includes(l)||(/b2b/i.test(v)&&v.includes('\u57fa\u7840\u4e1a\u52a1')));
  };
  const docs=()=>Array.from(new Set([doc,document].filter(Boolean)));
  const add=(arr,el)=>{if(el&&visible(el)&&!arr.includes(el))arr.push(el);};
  const controls=[];
  const anchors=elementsByText(doc,S.businessLine,'label,span,div,p,td,th').filter(el=>textOf(el).length<200);
  for(const a of anchors){
    let root=a;
    for(let i=0;i<7&&root;i++,root=root.parentElement){
      q(root,'.br-multiselect,.br-multiselect__controller,.br-popover__target,.br-select,[class*=select],[class*=Select],[class*=dropdown],[class*=Dropdown],[role=combobox],input:not([type=hidden]):not([disabled]),textarea:not([disabled]),select:not([disabled])').forEach(el=>add(controls,el));
    }
  }
  nearbyInputs(doc,S.businessLine).filter(el=>el.type!=='radio'&&el.type!=='checkbox').forEach(el=>add(controls,el));

  async function pickOpenedOption(){
    for(const d of docs()){
      const opts=q(d,'[role=option],li,div,span,a,[class*=option],[class*=Option],[class*=item],[class*=Item]')
        .filter(visible)
        .map(el=>({el,t:textOf(el)}))
        .filter(x=>x.t&&isTarget(x.t));
      opts.sort((a,b)=>{
        const ae=a.t===target?0:1,be=b.t===target?0:1;
        if(ae!==be)return ae-be;
        return a.t.length-b.t.length;
      });
      if(opts[0]){
        const el=opts[0].el;
        const targetEl=el.closest('[role=option],li,[class*=option],[class*=Option],[class*=item],[class*=Item]')||el;
        targetEl.scrollIntoView({block:'center',inline:'center'});
        targetEl.click();
        await sleep(500);
        return true;
      }
    }
    return false;
  }

  for(const ctrl of controls){
    try{
      ctrl.scrollIntoView({block:'center',inline:'center'});
      if(ctrl.tagName==='SELECT'){
        const opt=Array.from(ctrl.options).find(o=>isTarget(o.textContent)||isTarget(o.value));
        if(opt){
          ctrl.value=opt.value;
          ctrl.dispatchEvent(new Event('input',{bubbles:true}));
          ctrl.dispatchEvent(new Event('change',{bubbles:true}));
          return true;
        }
      }
      ctrl.click();
      await sleep(800);
