async function promoDoc(timeout=30000){for(let i=0;i<Math.ceil(timeout/250);i++){const f=document.querySelector('#iframeCon,iframe[name="iframeCon"]');let d=null;try{d=f?(f.contentDocument||f.contentWindow.document):document;}catch(e){d=document;}const body=d&&d.body;const txt=body?body.innerText:'';const url=[location.href,f&&f.getAttribute('src'),d&&d.location&&d.location.href].filter(Boolean).join(' ');if(body&&(/platform-promotions\/add-edit/.test(url)||S.sections.some(x=>txt.includes(x))||txt.includes(S.activityName))){return d;}await sleep(250);}throw new Error('platform promotion add page not loaded or iframeCon unavailable');}
