2026-05-09 16:29:04,394 [DEBUG] 数据解析: 'PromoScript.CodexActivityTimeDiagnosis.script' -> '(async()=>{
const sleep=ms=>new Promise(r=>setTimeout(r,ms));
const norm=s=>String(s||'').replace(/\s+/g,'').trim();
const visible=el=>!!el&&el.isConnected&&!!(el.offsetWidth||el.offsetHeight||el.getClientRects().length);
const textOf=el=>norm((el.innerText||el.textContent||el.value||el.getAttribute('title')||el.getAttribute('placeholder')||''));
const brief=el=>{
  if(!el)return null;
  const r=el.getBoundingClientRect();
  return {
    tag:el.tagName,id:el.id||'',cls:String(el.className||''),text:textOf(el).slice(0,200),
    value:String(el.value||''),placeholder:el.getAttribute('placeholder')||'',readonly:!!el.readOnly,
    type:el.getAttribute('type')||'',name:el.getAttribute('name')||'',html:el.outerHTML.slice(0,4000),
    rect:{x:Math.round(r.x),y:Math.round(r.y),w:Math.round(r.width),h:Math.round(r.height)}
  };
};
async function promoDoc(timeout=30000){
  for(let i=0;i<Math.ceil(timeout/250);i++){
    const f=document.querySelector('#iframeCon,iframe[name="iframeCon"]');
    let d=null;
    try{d=f?(f.contentDocument||f.contentWindow.document):document;}catch(e){d=document;}
    const txt=d&&d.body?d.body.innerText:'';
    const url=[location.href,f&&f.getAttribute('src'),d&&d.location&&d.location.href].filter(Boolean).join(' ');
    if(d&&d.body&&(/platform-promotions\/add-edit/.test(url)||txt.includes('活动时间')||txt.includes('活动名称')))return d;
    await sleep(250);
  }
  throw new Error('promo doc not loaded');
}
function uniqueText(items){return Array.from(new Set(items.filter(Boolean))).slice(0,240);}
const doc=await promoDoc();
const anchors=Array.from(doc.querySelectorAll('label,span,div,p,td,th')).filter(visible).filter(el=>textOf(el).includes('活动时间'));
const rows=[];
const controls=[];
for(const a of anchors){
  let root=a;
  for(let level=0;level<8&&root;level++,root=root.parentElement){
    const inputs=Array.from(root.querySelectorAll('input,textarea,select,.br-datepicker,.br-rangepicker,[class*=datepicker],[class*=Date]')).filter(visible);
    rows.push({level,anchor:brief(a),root:brief(root),inputs:inputs.map(brief)});
    controls.push(...inputs);
  }
}
const dateRoots=Array.from(new Set([
  ...Array.from(doc.querySelectorAll('.br-datepicker,.br-rangepicker,[class*=datepicker],[class*=Date]')).filter(visible),
  ...controls
]));
const clicked=[];
for(const ctrl of dateRoots.slice(0,12)){
  try{
    ctrl.scrollIntoView({block:'center',inline:'center'});
    await sleep(200);
    ctrl.click();
    await sleep(900);
    clicked.push({
      ctrl:brief(ctrl),
      topTexts:uniqueText(Array.from(document.querySelectorAll('body *')).filter(visible).map(textOf).filter(t=>/2026|今天|确定|清除|现在|时|分|秒|月|年|开始|结束|活动时间|请选择/.test(t)&&t.length<120)),
      frameTexts:uniqueText(Array.from(doc.querySelectorAll('body *')).filter(visible).map(textOf).filter(t=>/2026|今天|确定|清除|现在|时|分|秒|月|年|开始|结束|活动时间|请选择/.test(t)&&t.length<120))
    });
  }catch(e){clicked.push({ctrl:brief(ctrl),error:String(e).slice(0,300)});}
}
return {
  url:location.href,
  frameSrc:(document.querySelector('#iframeCon,iframe[name="iframeCon"]')||{}).src||'',
  docUrl:doc.location&&doc.location.href,
  bodyHead:(doc.body&&doc.body.innerText||'').slice(0,1200),
  anchors:anchors.map(brief),
  rows:rows.slice(0,40),
  dateRoots:dateRoots.map(brief),
  clicked
};
})()'
