<?xml version="1.0" encoding="UTF-8"?>
<cases step_wait="1" tags="platform-promotions,add-edit,system-manager">
  <case execute="是" id="PROMO_ADD_001" title="登录后直接访问平台促销活动新增页" description="使用管理中心账号登录后访问平台促销活动新增页，验证管理中心主框架 iframeCon 加载 merchant 子应用并展示核心表单分区。" component_type="界面" priority="P0">
    <pre_process>
      <test_step action="navigate" data="GlobalValue.Env.platform_promotion_add_url"/>
      <test_step action="wait" data="2"/>
      <test_step action="type" model="PassportLogin" data="ValidCredential"/>
      <test_step action="wait" data="5"/>
    </pre_process>
    <test_case>
      <test_step action="evaluate" data="PromoScript.PageLoadReady.script"/>
      <test_step action="screenshot" data="screenshots/PROMO_ADD_001_page_ready.png"/>
    </test_case>
    <post_process>
      <test_step action="close"/>
    </post_process>
  </case>

  <case execute="是" id="PROMO_ADD_002" title="未登录访问平台促销活动新增页应被认证拦截" description="清理浏览器状态后直接访问新增页，不应展示促销活动配置表单，应进入统一登录或认证拦截状态。" component_type="界面" priority="P0">
    <test_case>
      <test_step action="navigate" data="GlobalValue.Env.platform_promotion_add_url"/>
      <test_step action="wait" data="3"/>
      <test_step action="evaluate" data="PromoScript.UnauthenticatedBlocked.script"/>
    </test_case>
    <post_process>
      <test_step action="close"/>
    </post_process>
  </case>

