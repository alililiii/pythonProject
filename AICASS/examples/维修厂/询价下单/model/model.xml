<?xml version="1.0" encoding="UTF-8"?>
<models>
  <!-- ═══ 登录 ═══ -->
  <model name="ECAgentBuyLoginPage">
    <element name="accountTab">
      <location type="css" priority="1">span[type=PASSWORD]</location>
      <location type="xpath" priority="2">(//*[self::span or self::div or self::button][normalize-space(.)='账号登录'] | //*[self::span or self::div or self::button][contains(normalize-space(.),'账号') and contains(normalize-space(.),'登录')])[1]</location>
      <location type="xpath" priority="3">(//*[self::a or self::span or self::div or self::button][normalize-space(.)='退出'])[1]</location>
      <desc>账号登录页签</desc>
    </element>
    <element name="username">
      <location type="css">#userName</location>
      <desc>用户名输入框</desc>
    </element>
    <element name="password">
      <location type="css">#password</location>
      <desc>密码输入框</desc>
    </element>
    <element name="agreeCheckbox" type="web">
      <location type="css" priority="1">label.br-checkbox .br-checkbox__title</location>
      <location type="css" priority="2">label.br-checkbox</location>
      <desc>同意协议复选框</desc>
    </element>
    <element name="loginBtn">
      <location type="css">.btn-submit</location>
      <desc>登录按钮</desc>
    </element>
  </model>

  <model name="LoginSuccessCheck">
    <element name="publishInquiryTab" type="web">
      <type>text</type>
      <location type="xpath" priority="1">//a[normalize-space(.)='发布询价']</location>
      <location type="xpath" priority="2">//button[normalize-space(.)='发布询价']</location>
      <location type="xpath" priority="3">//*[self::a or self::button or self::span or self::div][contains(normalize-space(.),'发布询价') and not(.//*[contains(normalize-space(.),'发布询价')])]</location>
      <desc>登录成功后的发布询价入口</desc>
    </element>
  </model>

  <!-- ═══ 询价 ═══ -->
  <model name="InquiryPageCheck">
    <element name="publishInquiryTab" type="web">
      <type>text</type>
      <location type="xpath" priority="1">//a[normalize-space(.)='发布询价']</location>
      <location type="xpath" priority="2">//*[self::a or self::button or self::span][contains(normalize-space(.),'发布询价') and not(.//*[contains(normalize-space(.),'发布询价')])]</location>
      <desc>发布询价入口</desc>
    </element>
  </model>

  <!-- CHUNK2 -->

  <model name="InquiryFlow">
    <element name="vinInput" type="web">
      <type>input</type>
      <location type="xpath" priority="1">//input[contains(translate(@placeholder,'vin','VIN'),'VIN')]</location>
      <location type="css" priority="2">.vin-input</location>
      <desc>VIN输入框</desc>
    </element>
    <element name="vinInputSubmit" type="web">
      <type>input</type>
      <location type="xpath" priority="1">//input[contains(translate(@placeholder,'vin','VIN'),'VIN')]</location>
      <desc>VIN输入框回车提交</desc>
    </element>
    <element name="duplicateVinNewInquiryBtn" type="web">
      <type>button</type>
      <location type="xpath" priority="1">//button[contains(normalize-space(.),'不追加，发布新的询价单') or contains(normalize-space(.),'不追加')]</location>
      <desc>重复VIN弹窗-不追加按钮</desc>
    </element>
    <element name="partInputFirst" type="web">
      <type>textarea</type>
      <location type="xpath" priority="1">//table//tbody/tr[1]/td[2]//*[self::textarea or self::input][not(@disabled)]</location>
      <location type="xpath" priority="2">//table//tbody/tr[1]//textarea</location>
      <desc>首个零件号输入框</desc>
    </element>
    <element name="partInputFirstSubmit" type="web">
      <type>textarea</type>
      <location type="xpath" priority="1">//table//tbody/tr[1]/td[2]//*[self::textarea or self::input][not(@disabled)]</location>
      <desc>首个零件号输入框回车提交</desc>
    </element>
    <element name="cancelPlatformRecommendBtn" type="web">
      <type>checkbox</type>
      <location type="xpath" priority="1">//*[@group='store-distribute' and @id='system']</location>
      <desc>取消平台推荐</desc>
    </element>
    <element name="manualMerchantOption" type="web">
      <type>checkbox</type>
      <location type="xpath" priority="1">//*[@group='store-distribute' and @id='manual']</location>
      <desc>自行指定商家</desc>
    </element>
    <element name="publishInquiryBtn" type="web">
      <type>button</type>
      <location type="css" priority="1">.save-inquiry</location>
      <location type="xpath" priority="2">//input[contains(@class,'save-inquiry') and @type='button']</location>
      <location type="xpath" priority="3">//button[normalize-space(.)='发布询价']</location>
      <desc>发布询价按钮</desc>
    </element>
  </model>

  <!-- CHUNK3 -->

  <model name="InquiryPublishSuccessCheck">
    <element name="inquiryIdLabelWithGeneratedNo" type="web">
      <type>text</type>
      <location type="xpath" priority="1">//span[contains(@class,'header_inquiryId') and normalize-space(.)='询价单：']</location>
      <location type="xpath" priority="2">//span[contains(@class,'inquiryId') and normalize-space(.)='询价单：']</location>
      <desc>发布成功后的询价单标签</desc>
    </element>
    <element name="inquiryBNo" type="web">
      <type>text</type>
      <location type="xpath" priority="1">//span[contains(@class,'header_inquiryId') and normalize-space(.)='询价单：']/following::span[starts-with(normalize-space(.),'B') and string-length(normalize-space(.))>5][1]</location>
      <location type="xpath" priority="2">//*[contains(@class,'headerLeft')]//span[starts-with(normalize-space(.),'B') and string-length(normalize-space(.))>5]</location>
      <location type="xpath" priority="3">//*[contains(@class,'inquiryId')]/parent::*//span[starts-with(normalize-space(.),'B') and string-length(normalize-space(.))>5]</location>
      <desc>发布成功后的B开头询价单号</desc>
    </element>
  </model>

  <!-- ═══ 询价详情/报价页 ═══ -->
  <model name="InquiryQuotePage">
    <element name="purchaseBtn" type="web">
      <type>div</type>
      <location type="css" priority="1">[class*='purchase-btn']</location>
      <location type="xpath" priority="2">(//*[contains(@class,'purchase-btn') and normalize-space(.)='选购'])[1]</location>
      <location type="xpath" priority="3">(//div[contains(@class,'quotation-layer--quotation-row')]//*[normalize-space(.)='选购' and not(.//*[normalize-space(.)='选购'])])[1]</location>
      <location type="xpath" priority="4">(//*[normalize-space(.)='选购' and not(.//*[normalize-space(.)='选购'])])[1]</location>
      <desc>选购按钮（文本匹配，取第一个）</desc>
    </element>
  </model>

  <!-- ═══ 下单 ═══ -->
  <model name="QuoteListPage">
    <element name="refreshBtn" type="web">
      <type>button</type>
      <location type="xpath" priority="1">//*[@value='查询' or @value='刷新' or @value='重新查询' or @value='搜索']</location>
      <location type="xpath" priority="2">//button[normalize-space(.)='查询' or .//span[normalize-space(.)='查询']]</location>
      <location type="xpath" priority="3">//*[self::button or self::a or self::span or self::div][normalize-space(.)='刷新' and not(.//*[normalize-space(.)='刷新'])]</location>
      <location type="xpath" priority="4">//*[self::button or self::a or self::span or self::div][normalize-space(.)='重新查询' and not(.//*[normalize-space(.)='重新查询'])]</location>
      <location type="xpath" priority="5">//*[self::button or self::a or self::span or self::div][normalize-space(.)='搜索' and not(.//*[normalize-space(.)='搜索'])]</location>
      <desc>报价列表页查询/刷新按钮</desc>
    </element>
    <element name="quoteFinishedStatus">
      <location type="xpath" priority="1">(//table/tbody/tr[.//td[contains(normalize-space(.),'LBVFR790XBSD31722')] and .//td[contains(normalize-space(.),'61612458015')]])[1]/td[2]//div[contains(@class,'row')][1]</location>
      <location type="xpath" priority="2">//table/tbody/tr[1]/td[2]//div[contains(@class,'row')][1]</location>
      <desc>报价完成状态（按VIN+零件号定位目标行）</desc>
    </element>
    <element name="inquiryNoLink" type="web">
      <type>text</type>
      <location type="xpath" priority="1">(//table/tbody/tr[.//td[contains(normalize-space(.),'LBVFR790XBSD31722')] and .//td[contains(normalize-space(.),'61612458015')]])[1]//td[3]//a[starts-with(normalize-space(.),'B')]</location>
      <location type="xpath" priority="2">(//table/tbody/tr[.//td[contains(normalize-space(.),'LBVFR790XBSD31722')] and .//td[contains(normalize-space(.),'61612458015')]])[1]//td[3]//span[starts-with(normalize-space(.),'B')]</location>
      <desc>指定VIN与询价内容的目标询价单号</desc>
    </element>
  </model>

  <model name="OrderDetailReadyCheck">
    <element name="chooseBtnText" type="web">
      <type>div</type>
      <location type="css" priority="1">[class*='purchase-btn']</location>
      <location type="xpath" priority="2">(//*[contains(@class,'purchase-btn') and normalize-space(.)='选购'])[1]</location>
      <location type="xpath" priority="3">(//div[contains(@class,'quotation-layer--quotation-row')]//*[normalize-space(.)='选购' and not(.//*[normalize-space(.)='选购'])])[1]</location>
      <location type="xpath" priority="4">(//*[normalize-space(.)='选购' and not(.//*[normalize-space(.)='选购'])])[1]</location>
      <desc>任意可选购按钮（不限具体商品）</desc>
    </element>
  </model>

  <model name="OrderSelectionCheck">
    <element name="selectedSummary">
      <location type="xpath">//*[contains(normalize-space(.),'已选择') and contains(normalize-space(.),'共2件') and not(.//*[contains(normalize-space(.),'已选择') and contains(normalize-space(.),'共2件')])]</location>
      <desc>已选两件雨刮摘要</desc>
    </element>
  </model>

  <!-- CHUNK4 -->

  <model name="OrderDetailPage">
    <element name="chooseFirstWiperBtn" type="web">
      <type>div</type>
      <location type="xpath" priority="1">//div[contains(@class,'quotation-layer--quotation-row') and contains(@data-eventdata,'"productPartsNum":"571513"')]//*[contains(@class,'purchase-btn') and normalize-space(.)='选购']</location>
      <location type="xpath" priority="2">//div[contains(@class,'quotation-layer--quotation-row') and contains(@data-eventdata,'"productPartsNum":"571513"')]//*[contains(@class,'part-list--quotation-layer--purchase-btn') and normalize-space(.)='选购']</location>
      <location type="xpath" priority="3">//div[contains(@class,'quotation-layer--quotation-row') and contains(@data-eventdata,'"quotationIndex":"0"')]//*[normalize-space(.)='选购' and not(.//*[normalize-space(.)='选购'])]</location>
      <desc>第一个雨刮选购按钮</desc>
    </element>
    <element name="chooseSecondWiperBtn" type="web">
      <type>div</type>
      <location type="xpath" priority="1">//div[contains(@class,'quotation-layer--quotation-row') and contains(@data-eventdata,'"productPartsNum":"571518"')]//*[contains(@class,'purchase-btn') and normalize-space(.)='选购']</location>
      <location type="xpath" priority="2">//div[contains(@class,'quotation-layer--quotation-row') and contains(@data-eventdata,'"productPartsNum":"571518"')]//*[contains(@class,'part-list--quotation-layer--purchase-btn') and normalize-space(.)='选购']</location>
      <location type="xpath" priority="3">//div[contains(@class,'quotation-layer--quotation-row') and contains(@data-eventdata,'"quotationIndex":"1"')]//*[normalize-space(.)='选购' and not(.//*[normalize-space(.)='选购'])]</location>
      <desc>第二个雨刮选购按钮</desc>
    </element>
    <element name="buyNowBtn" type="web">
      <type>span</type>
      <location type="xpath" priority="1">//div[contains(@class,'tabBar_right')]//*[@data-desc='立即购买埋点' and normalize-space(.)='立即购买']</location>
      <location type="xpath" priority="2">//div[contains(@class,'tabBar_right')]//*[contains(@data-desc,'立即购买')]</location>
      <location type="xpath" priority="3">//div[contains(@class,'tabBar_right')]//*[self::span or self::button][normalize-space(.)='立即购买']</location>
      <desc>立即购买按钮</desc>
    </element>
  </model>

  <model name="CheckoutPage">
    <element name="checkoutBtn" type="web">
      <type>div</type>
      <location type="xpath" priority="1">//div[contains(@class,'buy-button') and contains(@class,'quick-buy') and normalize-space(.)='去结算']</location>
      <location type="xpath" priority="2">//div[@onclick='enableSettlementFeature();' and normalize-space(.)='去结算']</location>
      <desc>去结算按钮</desc>
    </element>
    <element name="submitOrderBtn" type="web">
      <type>button</type>
      <location type="xpath" priority="1">//button[.//span[normalize-space(.)='提交订单'] or normalize-space(.)='提交订单']</location>
      <location type="xpath" priority="2">//span[@class='br-button__content' and normalize-space(.)='提交订单']</location>
      <desc>提交订单按钮</desc>
    </element>
  </model>

  <!-- CHUNK5 -->

  <model name="PaymentPage">
    <element name="payNowBtn">
      <location type="xpath">//button[contains(normalize-space(.),'立即支付')]</location>
      <desc>立即支付按钮</desc>
    </element>
    <element name="verifyCodeInput">
      <location type="xpath">//input[@type='text' or @type='tel' or @placeholder='验证码']</location>
      <desc>验证码输入框</desc>
    </element>
    <element name="confirmPayBtn">
      <location type="xpath">//button[contains(normalize-space(.),'确认')]</location>
      <desc>确认支付按钮</desc>
    </element>
  </model>

  <model name="PaymentResultPage">
    <element name="paymentSuccessText">
      <location type="xpath">//*[contains(normalize-space(.),'感谢您，订单支付成功') and not(.//*[contains(normalize-space(.),'感谢您，订单支付成功')])]</location>
      <desc>支付成功提示</desc>
    </element>
    <element name="returnOrderListBtn">
      <location type="xpath" priority="1">//button[normalize-space(.)='返回订单列表' or .//span[normalize-space(.)='返回订单列表']]</location>
      <location type="xpath" priority="2">//*[self::a or self::button or self::span][normalize-space(.)='返回订单列表' and not(.//*[normalize-space(.)='返回订单列表'])]</location>
      <desc>返回订单列表按钮</desc>
    </element>
    <element name="orderTrackingBtn">
      <location type="xpath" priority="1">//header//a[contains(normalize-space(.),'订单跟踪')]</location>
      <location type="xpath" priority="2">//a[contains(normalize-space(.),'订单跟踪')]</location>
      <desc>订单跟踪按钮</desc>
    </element>
  </model>

  <!-- ═══ 维修厂订单列表 ═══ -->
  <model name="AgentOrderListPage">
    <element name="orderListReady" type="web">
      <type>text</type>
      <location type="xpath" priority="1">//*[contains(normalize-space(.),'订单号：') or contains(normalize-space(.),'询价单：')]</location>
      <location type="xpath" priority="2">//table | //*[contains(@class,'order') and contains(normalize-space(.),'订单')]</location>
      <desc>维修厂订单列表已加载</desc>
    </element>
  </model>

  <!-- ═══ 商家工作台登录/订单列表 ═══ -->
  <model name="ECSellerLoginPage">
    <element name="accountTab" type="web">
      <location type="css" priority="1">span[type=PASSWORD]</location>
      <location type="xpath" priority="2">//*[@id='userName']/ancestor::form//span[contains(@class,'tab')]</location>
      <location type="xpath" priority="3">//body</location>
      <desc>账号登录页签（已登录时 fallback 到 body 无害点击）</desc>
    </element>
    <element name="username" type="web">
      <type>input</type>
      <location type="css">#userName</location>
      <desc>用户名输入框</desc>
    </element>
    <element name="password" type="web">
      <type>input</type>
      <location type="css">#password</location>
      <desc>密码输入框</desc>
    </element>
    <element name="agreeCheckbox" type="web">
      <location type="css" priority="1">label.br-checkbox .br-checkbox__title</location>
      <location type="css" priority="2">label.br-checkbox</location>
      <desc>同意协议复选框</desc>
    </element>
    <element name="loginBtn" type="web">
      <location type="css">.btn-submit</location>
      <desc>登录按钮</desc>
    </element>
  </model>

  <model name="ECSellerWorkbenchCheck">
    <element name="workbenchTitle" type="web">
      <location type="xpath" priority="1">//*[contains(normalize-space(.),'工作台') and not(.//*[contains(normalize-space(.),'工作台')])]</location>
      <location type="xpath" priority="2">//*[contains(normalize-space(.),'商家') and not(.//*[contains(normalize-space(.),'商家')])]</location>
      <location type="xpath" priority="3">//*[contains(normalize-space(.),'首页') and not(.//*[contains(normalize-space(.),'首页')])]</location>
      <desc>商家工作台首页确认</desc>
    </element>
  </model>

  <model name="ECSellerOrderListEntry">
    <element name="leftMenuSearchInput" type="web">
      <type>input</type>
      <location type="xpath" priority="1">//input[@placeholder='搜索关键字']</location>
      <location type="xpath" priority="2">//aside//input[contains(@placeholder,'搜索') or contains(@class,'search')]</location>
      <desc>商家工作台左侧搜索框</desc>
    </element>
    <element name="orderListMenu" type="web">
      <type>button</type>
      <location type="xpath" priority="1">//*[self::li or self::a or self::span or self::div][normalize-space(.)='订单列表' and not(.//*[normalize-space(.)='订单列表'])]</location>
      <location type="xpath" priority="2">//li[contains(@class,'menu') and contains(normalize-space(.),'订单列表')]</location>
      <desc>订单列表菜单项</desc>
    </element>
  </model>

  <model name="ECSellerOrderListPage">
    <element name="orderNoInput" type="web">
      <type>input</type>
      <location type="xpath" priority="1">//*[contains(normalize-space(.),'订单编号')]/following::input[1]</location>
      <location type="xpath" priority="2">//input[contains(@placeholder,'订单编号') or contains(@placeholder,'订单号')]</location>
      <desc>订单编号查询输入框</desc>
    </element>
    <element name="orderNoInputSubmit" type="web">
      <type>input</type>
      <location type="xpath" priority="1">//*[contains(normalize-space(.),'订单编号')]/following::input[1]</location>
      <location type="xpath" priority="2">//input[contains(@placeholder,'订单编号') or contains(@placeholder,'订单号')]</location>
      <desc>订单编号查询输入框回车提交</desc>
    </element>
  </model>

  <model name="ECSellerOrderListCheck">
    <element name="orderListTitle" type="web">
      <type>text</type>
      <location type="xpath" priority="1">//*[normalize-space(.)='订单列表' and not(.//*[normalize-space(.)='订单列表'])]</location>
      <location type="xpath" priority="2">//*[contains(normalize-space(.),'订单编号') and not(.//*[contains(normalize-space(.),'订单编号')])]</location>
      <desc>订单列表页面标题或查询条件</desc>
    </element>
  </model>

  <!-- ═══ 出库 ═══ -->
  <model name="OrderTrackingPage">
    <element name="latestOrderRow" type="web">
      <type>tr</type>
      <location type="xpath" priority="1">//table/tbody/tr[1]</location>
      <location type="xpath" priority="2">//div[contains(@class,'order-list')]//div[contains(@class,'order-item')][1]</location>
      <desc>订单跟踪列表第一行</desc>
    </element>
    <element name="latestOrderLink" type="web">
      <type>a</type>
      <location type="xpath" priority="1">//table/tbody/tr[1]//a[starts-with(normalize-space(.),'D') or starts-with(normalize-space(.),'O')]</location>
      <location type="xpath" priority="2">//div[contains(@class,'order-item')][1]//a</location>
      <desc>最新订单号链接</desc>
    </element>
  </model>

  <model name="OrderTrackingDetailPage">
    <element name="shippedStatusText" type="web">
      <type>text</type>
      <location type="xpath" priority="1">//*[contains(normalize-space(.),'已出库') and not(.//*[contains(normalize-space(.),'已出库')])]</location>
      <location type="xpath" priority="2">//*[contains(normalize-space(.),'已发货') and not(.//*[contains(normalize-space(.),'已发货')])]</location>
      <desc>已出库/已发货状态文本</desc>
    </element>
    <element name="confirmReceiveBtn" type="web">
      <type>button</type>
      <location type="xpath" priority="1">//button[normalize-space(.)='确认收货' or .//span[normalize-space(.)='确认收货']]</location>
      <location type="xpath" priority="2">//*[self::button or self::a or self::span][normalize-space(.)='确认收货' and not(.//*[normalize-space(.)='确认收货'])]</location>
      <desc>确认收货按钮</desc>
    </element>
    <element name="receivedStatusText" type="web">
      <type>text</type>
      <location type="xpath" priority="1">//*[contains(normalize-space(.),'已收货') and not(.//*[contains(normalize-space(.),'已收货')])]</location>
      <location type="xpath" priority="2">//*[contains(normalize-space(.),'已完成') and not(.//*[contains(normalize-space(.),'已完成')])]</location>
      <desc>已收货/已完成状态文本</desc>
    </element>
  </model>

  <!-- ═══ 收货确认弹窗 ═══ -->
  <model name="ReceiveConfirmDialog">
