    for(const part of String(cfg.areaDetails).split('>').map(x=>x.trim()).filter(Boolean)){
      await clickText(doc,part,false);
      await sleep(150);
    }
  }
  await chooseExactOrToken(doc,cfg.customerMode,null,false);
  await chooseExactOrToken(doc,cfg.customerConfigMode,null,false);
  await chooseDetails(doc,cfg.customerItems,'code');
  await applyException(doc,cfg.customerException,'customer');
  await chooseExactOrToken(doc,cfg.promoType,null,!!cfg.promoType);
  const ruleInfo=await fillRules(doc,cfg);
  await chooseExactOrToken(doc,cfg.budgetMode,null,false);
  if(cfg.budgetLimit)inputByLabel(doc,S.budget,String(cfg.budgetLimit));
  await chooseExactOrToken(doc,cfg.stackMode,null,false);
  await chooseExactOrToken(doc,cfg.storeMode,null,false);
  await chooseExactOrToken(doc,cfg.storeConfigMode,null,false);
  await chooseDetails(doc,cfg.storeItems,'code');
  await applyException(doc,cfg.storeException,'store');
  const goodsFallback=String(cfg.goodsScope||'').includes('\u6309\u5546\u54c1')?S.byProduct:S.byCategory;
  await chooseExactOrToken(doc,cfg.goodsScope,goodsFallback,false);
  await chooseExactOrToken(doc,cfg.goodsLimitType,null,false);
  await chooseExactOrToken(doc,cfg.qualityMode,null,false);
  await chooseDetails(doc,cfg.qualityDetails,'text');
  await chooseExactOrToken(doc,cfg.partBrandMode,null,false);
  await chooseDetails(doc,cfg.partBrandDetails,'text');
  await chooseExactOrToken(doc,cfg.categoryMode,null,false);
  await chooseDetails(doc,cfg.categoryDetails,'text');
  await chooseDetails(doc,cfg.productDetails,'code');
  window.__promoAutomation=Object.assign(window.__promoAutomation||{},{lastScenario:cfg,lastActivityName:activityName,lastActivityTime:time});
  window.__promoScenarioAutomation.lastScenario=cfg;
  return {status:'scenario-configured',caseId:cfg.caseId,activityName,time,ruleInfo};
}
async function saveExpectSuccess(){
  const doc=await promoDoc();
  const before=window.__promoAutomation&&window.__promoAutomation.lastActivityName||'';
  const txt=await clickSave(doc);
  const topText=document.body?document.body.innerText:'';
  const combined=txt+'\n'+topText;
  const onList=/\u6d3b\u52a8\u5217\u8868|\u65b0\u589e\u6d3b\u52a8|\u4e0b\u8f7d\u6d3b\u52a8\u6e05\u5355|\u4e3a\u60a8\u627e\u5230/.test(combined);
  const created=before&&combined.includes(before.slice(0,Math.min(before.length,28)));
  if(hasSuccess(combined)||onList||created){
    return {status:'save-submitted',activityName:before,onList,created};
  }
  if(hasValidation(combined))throw new Error('save validation: '+combined.slice(0,400));
  throw new Error('save result unknown, activityName='+before+', text='+combined.slice(0,400));
}
async function saveExpectValidation(){
  const doc=await promoDoc();
  const txt=await clickSave(doc);
  const topText=document.body?document.body.innerText:'';
  const combined=txt+'\n'+topText;
  if(hasSuccess(combined))throw new Error('negative scenario saved unexpectedly');
  if(!hasValidation(combined))throw new Error('validation message not found: '+combined.slice(0,400));
  return {status:'validation-rejected',caseId:(window.__promoAutomation&&window.__promoAutomation.lastScenario&&window.__promoAutomation.lastScenario.caseId)||''};
}
window.__promoScenarioAutomation={promoDoc,configureScenario,saveExpectSuccess,saveExpectValidation,clickSave,hasSuccess,hasValidation};
return {status:'scenario-engine-ready'};
})()
