function formatDate(d){const p=n=>String(n).padStart(2,'0');return d.getFullYear()+'-'+p(d.getMonth()+1)+'-'+p(d.getDate())+' '+p(d.getHours())+':'+p(d.getMinutes())+':'+p(d.getSeconds());}
function fillActivityTime(doc){
  const start=new Date(), end=new Date(start.getTime()+10*60*1000);
  const startText=formatDate(start), endText=formatDate(end);
  function day(d){
    const p=n=>String(n).padStart(2,'0');
    return d.getFullYear()+'-'+p(d.getMonth()+1)+'-'+p(d.getDate());
  }
  function fiber(el){
    const key=Object.keys(el).find(k=>k.startsWith('__reactInternalInstance')||k.startsWith('__reactFiber'));
    return key?el[key]:null;
  }
  function mk(gen,d){
    let x=gen.getFixedDate(day(d));
    x=gen.setHour(x,d.getHours());
    x=gen.setMinute(x,d.getMinutes());
    x=gen.setSecond(x,d.getSeconds());
    return x;
  }
  const range=doc.querySelector('.br-datepicker-range,.br-rangepicker,.br-datepicker');
  if(range){
    let f=fiber(range);
    for(let i=0;i<15&&f;i++,f=f.return){
      const p=f.memoizedProps||{};
      if(typeof p.onChange==='function'&&Array.isArray(p.value)&&p.format==='YYYY-MM-DD HH:mm:ss'&&p.generateConfig){
        const value=[mk(p.generateConfig,start),mk(p.generateConfig,end)];
        p.onChange(value,[startText,endText]);
        const inputs=Array.from(range.querySelectorAll('input'));
        if(inputs[0]&&inputs[1]){
          setValue(inputs[0],startText);
          setValue(inputs[1],endText);
        }
        return {start:startText,end:endText};
      }
    }
  }
  let inputs=nearbyInputs(doc,S.activityTime).filter(el=>el.type!=='radio'&&el.type!=='checkbox');
  if(inputs.length<2){
    inputs=q(doc,'input:not([type=hidden]):not([disabled]),input[readonly],textarea:not([disabled])')
      .filter(visible)
      .filter(el=>/(date|time|yyyy|YYYY|\u65e5\u671f)/i.test([el.type,el.placeholder,el.className,el.name].join(' ')));
  }
  if(inputs[0])setValue(inputs[0],startText);
  if(inputs[1])setValue(inputs[1],endText);
  return {start:startText,end:endText};
}
async function chooseBusinessLine(doc,line){
  const target=norm(line||'B2b-\u57fa\u7840\u4e1a\u52a1');
  const loose=s=>norm(s).replace(/[-_\uff0d]/g,'').toLowerCase();
  const targetLoose=loose(target);
  const isTarget=t=>{
    const v=norm(t),l=loose(v);
    return v&&(v===target||v.includes(target)||target.includes(v)||l===targetLoose||l.includes(targetLoose)||targetLoose.includes(l)||(/b2b/i.test(v)&&v.includes('\u57fa\u7840\u4e1a\u52a1')));
  };
  const docs=()=>Array.from(new Set([doc,document].filter(Boolean)));
  const add=(arr,el)=>{if(el&&visible(el)&&!arr.includes(el))arr.push(el);};
  const controls=[];
  const anchors=elementsByText(doc,S.businessLine,'label,span,div,p,td,th').filter(el=>textOf(el).length<200);
  for(const a of anchors){
    let root=a;
    for(let i=0;i<7&&root;i++,root=root.parentElement){
      q(root,'.br-multiselect,.br-multiselect__controller,.br-popover__target,.br-select,[class*=select],[class*=Select],[class*=dropdown],[class*=Dropdown],[role=combobox],input:not([type=hidden]):not([disabled]),textarea:not([disabled]),select:not([disabled])').forEach(el=>add(controls,el));
    }
  }
  nearbyInputs(doc,S.businessLine).filter(el=>el.type!=='radio'&&el.type!=='checkbox').forEach(el=>add(controls,el));

  async function pickOpenedOption(){
    for(const d of docs()){
      const opts=q(d,'[role=option],li,div,span,a,[class*=option],[class*=Option],[class*=item],[class*=Item]')
        .filter(visible)
        .map(el=>({el,t:textOf(el)}))
        .filter(x=>x.t&&isTarget(x.t));
      opts.sort((a,b)=>{
        const ae=a.t===target?0:1,be=b.t===target?0:1;
        if(ae!==be)return ae-be;
        return a.t.length-b.t.length;
      });
      if(opts[0]){
        const el=opts[0].el;
        const targetEl=el.closest('[role=option],li,[class*=option],[class*=Option],[class*=item],[class*=Item]')||el;
        targetEl.scrollIntoView({block:'center',inline:'center'});
        targetEl.click();
        await sleep(500);
        return true;
      }
    }
    return false;
  }

  for(const ctrl of controls){
    try{
      ctrl.scrollIntoView({block:'center',inline:'center'});
      if(ctrl.tagName==='SELECT'){
        const opt=Array.from(ctrl.options).find(o=>isTarget(o.textContent)||isTarget(o.value));
        if(opt){
          ctrl.value=opt.value;
          ctrl.dispatchEvent(new Event('input',{bubbles:true}));
          ctrl.dispatchEvent(new Event('change',{bubbles:true}));
          return true;
        }
      }
      ctrl.click();
      await sleep(800);
      if(await pickOpenedOption())return true;
    }catch(e){}
  }
  if(await pickOpenedOption())return true;
  throw new Error('business line option not found: '+target);
}
async function clickOption(doc,option,required=false){return clickText(doc,option,required);}
async function addCode(doc,code,kind){
  function modalRoots(){
    const candidates=q(doc,'.br-modal,.br-dialog,[class*=modal],[class*=Modal],[class*=dialog],[class*=Dialog],body')
      .filter(visible);
    const withInput=candidates.filter(root=>q(root,'input:not([type=hidden]):not([disabled]),textarea:not([disabled])').filter(visible).length);
    return (withInput.length?withInput:candidates)
      .sort((a,b)=>a.getBoundingClientRect().width*a.getBoundingClientRect().height-b.getBoundingClientRect().width*b.getBoundingClientRect().height);
  }
  async function waitForModal(timeout=4000){
    for(let i=0;i<Math.ceil(timeout/200);i++){
      const roots=modalRoots();
      if(roots.length)return roots[0];
      await sleep(200);
    }
    return null;
  }
  async function waitModalClosed(root,timeout=5000){
    for(let i=0;i<Math.ceil(timeout/250);i++){
      if(!root||!root.isConnected||!visible(root))return true;
      if(!textOf(root).includes(code)&&!textOf(root).includes('\u6dfb\u52a0'))return true;
      await sleep(250);
    }
    return false;
  }
  function confirmButton(root){
    const buttons=q(root,'button').filter(visible).map(el=>({el,t:textOf(el)})).filter(x=>x.t==='\u786e\u5b9a');
    if(buttons.length)return buttons[buttons.length-1].el;
    const spans=q(root,'span,a,div').filter(visible).map(el=>({el,t:textOf(el)})).filter(x=>x.t==='\u786e\u5b9a');
    return spans.length?(spans[spans.length-1].el.closest('button,a')||spans[spans.length-1].el):null;
  }
  async function fillModal(root){
    let inputs=q(root,'input:not([type=hidden]):not([disabled]),textarea:not([disabled])')
      .filter(visible)
      .filter(el=>!/(date|time)/i.test([el.type,el.placeholder,el.className,el.name].join(' ')));
    if(!inputs.length){
      inputs=q(doc,'input:not([type=hidden]):not([disabled]),textarea:not([disabled])').filter(visible)
        .filter(el=>!/(date|time)/i.test([el.type,el.placeholder,el.className,el.name].join(' ')));
    }
    const empty=inputs.find(el=>!el.value)||inputs[0];
    if(!empty)throw new Error('code input not found in modal for '+code);
    setValue(empty,code);
    empty.dispatchEvent(new KeyboardEvent('keydown',{key:'Enter',bubbles:true}));
    empty.dispatchEvent(new KeyboardEvent('keyup',{key:'Enter',bubbles:true}));
    empty.blur&&empty.blur();
    await sleep(1800);
    for(let attempt=0;attempt<3;attempt++){
      const txt=textOf(root);
      if(/未找到|不存在|错误/.test(txt))throw new Error('add code validation failed for '+code+': '+txt.slice(0,220));
      const ok=confirmButton(root)||confirmButton(doc.body);
      if(!ok)throw new Error('modal confirm button not found for '+code);
      ok.click();
      await sleep(1200);
      if(await waitModalClosed(root,1500))return true;
    }
    throw new Error('modal did not close after adding '+code+': '+textOf(root).slice(0,220));
  }
  let root=modalRoots()[0];
  if(!root||root===doc.body){
    const openLabels=kind==='store'?['\u6dfb\u52a0\u5e97\u94fa','\u6dfb\u52a0']:['\u6dfb\u52a0\u7ef4\u4fee\u5382','\u6dfb\u52a0\u5ba2\u6237','\u6dfb\u52a0'];
    await clickText(doc,openLabels,false);
    root=await waitForModal(5000);
  }
  if(!root)throw new Error('add code modal not opened for '+code);
  return await fillModal(root);
}
async function configureCombo(doc,cfg){requireText(doc,S.sections,'combo configuration page');const activityName='\u81ea\u52a8\u5316-\u5e73\u53f0\u4fc3\u9500-\u7ec4\u5408-'+Date.now()+'-'+cfg.caseId;inputByLabel(doc,S.activityName,activityName);const time=fillActivityTime(doc);await clickOption(doc,cfg.business==='inquiry'?S.inquiry:S.mall,false);await chooseBusinessLine(doc,cfg.businessLine||'B2b-\u57fa\u7840\u4e1a\u52a1');await clickOption(doc,cfg.area==='byArea'?S.byArea:S.unlimitedArea,true);if(cfg.area==='byArea'&&cfg.regionCode)await clickOption(doc,S.beijing,false);await clickOption(doc,cfg.customerMode==='include'?S.includeCustomer:cfg.customerMode==='exclude'?S.excludeCustomer:S.allCustomers,true);if((cfg.customerMode==='include'||cfg.customerMode==='exclude')&&cfg.customerCode)await addCode(doc,cfg.customerCode,'customer');await clickOption(doc,cfg.promoType==='reduction'?S.reduction:S.discount,true);fillFirstNumbers(doc,cfg.promoType==='reduction'?[cfg.threshold,cfg.reduction,cfg.share]:[cfg.threshold,cfg.discount,cfg.share]);await clickOption(doc,cfg.budgetMode==='limit'?S.budgetLimit:S.noLimit,true);if(cfg.budgetMode==='limit')inputByLabel(doc,S.budget,String(cfg.budgetValue||1000));await clickOption(doc,cfg.stack?S.stack:S.noStack,true);await clickOption(doc,cfg.storeMode==='include'?S.includeStore:cfg.storeMode==='exclude'?S.excludeStore:S.unlimitedStore,true);if((cfg.storeMode==='include'||cfg.storeMode==='exclude')&&cfg.storeCode)await addCode(doc,cfg.storeCode,'store');await clickOption(doc,S.byCategory,true);await clickOption(doc,cfg.qualityMode==='specified'?S.specifiedQuality:S.unlimitedQuality,true);if(cfg.qualityMode==='specified'&&cfg.qualityName)await clickOption(doc,S.original,false);await clickOption(doc,cfg.brandMode==='specified'?S.specifiedBrand:S.unlimitedBrand,false);if(cfg.brandMode==='specified')await clickText(doc,['\u7b2c\u4e00\u4e2a\u54c1\u724c',S.select],false);await clickOption(doc,cfg.categoryMode==='specified'?S.specifiedCategory:S.unlimitedCategory,false);if(cfg.categoryMode==='specified')await clickText(doc,[S.select,'\u7b2c\u4e00\u4e2a\u54c1\u7c7b'],false);window.__promoAutomation=Object.assign(window.__promoAutomation||{},{lastCombo:cfg,lastActivityName:activityName,lastActivityTime:time});return {caseId:cfg.caseId,activityName,time};}
async function clickSave(doc){await clickText(doc,S.save,true);await sleep(1600);return bodyText(doc);}
function hasSuccess(text){return /\u4fdd\u5b58\u6210\u529f|\u64cd\u4f5c\u6210\u529f|\u6210\u529f/.test(text);}
function hasValidation(text){return /\u5fc5\u586b|\u8bf7\u9009\u62e9|\u4e0d\u80fd\u4e3a\u7a7a|\u4e0d\u53ef\u4e3a\u7a7a|\u8303\u56f4|0\.01|9\.99|\u5927\u4e8e|\u4e0d\u5408\u6cd5|\u9519\u8bef|\u5931\u8d25/.test(text);}


function promoItems(value){
  if(!value)return [];
  return String(value).split(';').map(x=>x.trim()).filter(x=>x && x!=='null' && x!=='None' && x!=='\u4e0d\u9002\u7528');
}
function itemCode(value){
  const text=String(value||'').trim();
  if(!text)return '';
  const m=text.match(/[A-Za-z0-9_-]+/);
  return m?m[0]:text;
}
function ruleSize(cfg){
  const text=String(cfg.ruleCount||'');
  if(/\u4e24|2/.test(text))return 2;
  const sizes=[cfg.orderAmounts,cfg.benefitValues,cfg.platformShares].map(v=>String(v||'').split(';').length);
  return Math.max(1,...sizes);
}
function numberInputs(root){
  return q(root,'input:not([type=hidden]):not([disabled]),textarea:not([disabled])')
    .filter(visible)
    .filter(el=>!/(date|time)/i.test([el.type,el.placeholder,el.className,el.name].join(' ')));
}
function promoRuleTable(doc){
  const tables=q(doc,'table').filter(visible);
  return tables.find(t=>textOf(t).includes(S.orderAmount)&&(/\u5e73\u53f0\u5206\u644a/.test(textOf(t))||textOf(t).includes(S.platformShare))) || tables[0] || null;
}
async function ensureRuleRows(doc,table,count){
  for(let i=0;i<count;i++){
    let rows=q(table,'tbody tr,tr').filter(visible).filter(r=>numberInputs(r).length);
    if(rows.length>=count)return rows;
    await clickText(doc,[S.addRule,'\u65b0\u589e','\u6dfb\u52a0'],false);
    await sleep(400);
  }
  return q(table,'tbody tr,tr').filter(visible).filter(r=>numberInputs(r).length);
}
async function fillRules(doc,cfg){
  const table=promoRuleTable(doc);
  const amounts=String(cfg.orderAmounts||'').split(';');
  const benefits=String(cfg.benefitValues||'').split(';');
  const shares=String(cfg.platformShares||'').split(';');
  const count=ruleSize(cfg);
  if(table){
    const rows=await ensureRuleRows(doc,table,count);
    for(let i=0;i<count;i++){
      const row=rows[i]||rows[rows.length-1]||table;
      const inputs=numberInputs(row);
      const vals=[amounts[i]||'',benefits[i]||'',shares[i]||''];
      vals.forEach((v,idx)=>{ if(v!==''&&inputs[idx])setValue(inputs[idx],v); });
    }
    return {mode:'table',count,rows:rows.length};
  }
  const inputs=numberInputs(doc);
  const vals=[];
  for(let i=0;i<count;i++)vals.push(amounts[i]||'',benefits[i]||'',shares[i]||'');
  vals.forEach((v,idx)=>{ if(v!==''&&inputs[idx])setValue(inputs[idx],v); });
  return {mode:'fallback',count,inputs:inputs.length};
}
async function chooseExactOrToken(doc,value,fallback,required=false){
  if(value&&await clickText(doc,value,false))return true;
  if(fallback&&await clickText(doc,fallback,false))return true;
  if(required)throw new Error('option not found: '+(value||fallback));
  return false;
}
async function chooseDetails(doc,value,kind){
  const items=promoItems(value);
  for(const item of items){
    if(await clickText(doc,item,false))continue;
    if(kind==='code'){
      await addCode(doc,itemCode(item),kind);
    }else{
      await clickText(doc,[S.select,itemCode(item)],false);
    }
  }
}
async function applyException(doc,value,kind){
  if(!value)return;
  await clickText(doc,['\u4f8b\u5916','\u6dfb\u52a0\u4f8b\u5916','\u8bbe\u7f6e\u4f8b\u5916'],false);
  if(String(value).includes('\u5df2\u5f00\u542f'))return;
  const cleaned=String(value).replace(/^\u4f8b\u5916:/,'');
  for(const item of promoItems(cleaned)){
    await addCode(doc,itemCode(item),kind);
  }
}
async function configureScenario(cfg){
  const doc=await promoDoc();
  requireText(doc,S.sections,'scenario page');
  const base=cfg.activityBaseName;
  const activityName=base?('\u81ea\u52a8\u5316-\u5e73\u53f0\u4fc3\u9500-'+base+'-'+Date.now()):'';
  if(activityName)inputByLabel(doc,S.activityName,activityName);
