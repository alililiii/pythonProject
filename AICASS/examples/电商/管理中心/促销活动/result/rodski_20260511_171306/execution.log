    const benefit=Number(values[1]);
    const share=Number(values[2]);
    if(/\u5206\u644a\u91d1\u989d/.test(tableText)&&Number.isFinite(benefit)&&Number.isFinite(share)&&share>benefit&&share<=100){
      const amount=Math.round(benefit*share)/100;
      return String(amount).replace(/\.0+$/,'');
