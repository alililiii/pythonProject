    const bodyRows=q(table,'tbody tr,tr').filter(visible);
    const row=bodyRows.find(r=>numberInputs(r).length)||table;
    const inputs=numberInputs(row);
    function setByHeader(pattern,value,fallbackIndex){
      let header=headers.find(h=>pattern.test(h.t));
      let input=null;
      if(header&&header.i>=0){
        const cells=q(row,'td,th').filter(visible);
        const cell=cells[header.i];
        if(cell)input=numberInputs(cell)[0];
      }
      if(!input)input=inputs[fallbackIndex];
      if(input)setValue(input,value);
      return !!input;
    }
    const isReduction=String(values[1])==='10'||textOf(table).includes(S.reductionAmount)||textOf(table).includes('\u4f18\u60e0\u91d1\u989d')||textOf(table).includes('\u7acb\u51cf\u91d1\u989d');
    const shareValue=amountShareValue(table);
    setByHeader(/\u8ba2\u5355\u91d1\u989d/,values[0],0);
    setByHeader(isReduction?/(\u4f18\u60e0\u91d1\u989d|\u7acb\u51cf|\u51cf)/:/(\u6298\u6263)/,values[1],1);
    setByHeader(/\u5e73\u53f0\u5206\u644a/,shareValue,2);
    return {count:inputs.length,values:inputs.map(el=>el.value),shareValue};
  }
