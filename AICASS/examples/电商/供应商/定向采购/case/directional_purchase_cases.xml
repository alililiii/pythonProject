  <case execute="是" id="DIR-FLOW-011" title="供应商为维修厂下单，维修厂查看订单" description="完整链路：供应商登录→定向采购下单→保存订单号→导航到维修厂首页→登录维修厂→点击订单跟踪→更多条件→输入订单编号→查询→点击订单详情→校验。" component_type="界面" priority="P2">
    <test_case>
      <scenario id="S001" title="供应商登录并提交定向采购订单" group="seller-submit" tag="submit,p2">
        <test_step action="navigate" data="GlobalValue.Env.directional_purchase_url"/>
        <test_step action="wait" data="2"/>
        <test_step action="type" model="PassportLogin" data="SellerPrimaryCredential"/>
        <test_step action="wait" data="8"/>
        <test_step action="evaluate" data="DirectionalScript.ScenarioEngine.script"/>
        <test_step action="evaluate" data="DirectionalScript.PageReady.script"/>
        <test_step action="evaluate" data="DirectionalScenario.DIR_FLOW_011.script"/>
        <test_step action="evaluate" data="DirectionalScript.SubmitOrderFlow.script"/>
      </scenario>
      <scenario id="S002" title="退出供应商账号，登录维修厂账号进入首页点击订单跟踪" group="garage-login" tag="garage,p2" depends="S001">
        <test_step action="evaluate" data="((() => { const orderNo = window.__directionalLastSubmit &amp;&amp; window.__directionalLastSubmit.orderNo; localStorage.setItem('__garageOrderNo', orderNo); return orderNo; })())"/>
        <test_step action="navigate" data="GlobalValue.Env.logout_url"/>
        <test_step action="wait" data="3"/>
        <test_step action="navigate" data="GlobalValue.Env.mall_portal_url"/>
        <test_step action="wait" data="2"/>
        <test_step action="type" model="PassportLogin" data="GarageLoginCredential"/>
        <test_step action="wait" data="10"/>
        <test_step action="evaluate" data="((async () => { const sleep = ms => new Promise(r => setTimeout(r, ms)); const visible = el => !!el &amp;&amp; el.isConnected &amp;&amp; !!(el.offsetWidth || el.offsetHeight || el.getClientRects().length); const q = sel => [...document.querySelectorAll(sel)].filter(visible); const norm = s => String(s || '').replace(/\s+/g, ' ').trim(); for (let i = 0; i &lt; 30; i++){ const link = q('a,span,div,button').find(el => { const t = norm(el.innerText || el.textContent || ''); return t === '订单跟踪'; }); if (link){ link.click(); return 'clicked'; } await sleep(500); } throw new Error('订单跟踪 not found'); })())"/>
        <test_step action="wait" data="5"/>
      </scenario>
      <scenario id="S003" title="更多条件搜索订单号并进入订单详情校验" group="garage-verify" tag="garage,verify,p2" depends="S002">
        <test_step action="evaluate" data="DirectionalScript.GarageOrderTracking.script"/>
      </scenario>
      <scenario id="S004" title="截图留存维修厂订单详情" group="evidence" tag="screenshot" depends="S003">
        <test_step action="screenshot" data="screenshots/DIR_FLOW_011_garage_detail.png"/>
      </scenario>
    </test_case>
    <post_process>
      <test_step action="close"/>
    </post_process>
  </case>

